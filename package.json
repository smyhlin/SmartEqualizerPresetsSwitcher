{
  "name": "smarteqpresetswitcher",
  "version": "0.3.0",
  "private": true,
  "description": "Cross-platform EQ preset switcher with Windows Equalizer APO and Linux PipeWire export support.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri",
    "bootstrap:linux": "bash scripts/bootstrap-linux.sh",
    "build:linux": "bash scripts/build-linux.sh",
    "build:arch": "bash scripts/build-arch-package.sh",
    "build:deb": "bash scripts/build-deb.sh",
    "bootstrap:windows": "scripts\\bootstrap-windows.bat",
    "build:windows": "scripts\\build-windows.bat",
    "check:project": "bash scripts/check-project.sh",
    "check:source": "bash scripts/check-project.sh --strict-source --skip-npm --skip-cargo",
    "check:clean-source": "bash scripts/check-project.sh --strict-source --fail-local-generated --skip-npm --skip-cargo",
    "build:linux:deb": "bash scripts/build-linux.sh --deb",
    "build:linux:appimage": "bash scripts/build-linux.sh --appimage",
    "build:linux:all": "bash scripts/build-linux.sh --all",
    "build:linux:auto": "bash scripts/build-linux.sh --auto",
    "build:linux:arch": "bash scripts/build-linux.sh --arch",
    "build:linux:windows": "bash scripts/build-linux.sh --windows",
    "build:windows:linux": "bash scripts/build-windows-from-linux.sh"
  },
  "dependencies": {
    "@lucide/svelte": "1.8.0",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "2.7.0",
    "@thisux/sveltednd": "^0.4.0",
    "clsx": "2.1.1",
    "shadcn-svelte": "1.2.7",
    "svelte": "5.55.3",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "25.6.0",
    "svelte-check": "4.4.6",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  }
}
